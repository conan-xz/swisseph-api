PORT=3000
NODE_ENV=production
SSL_ENABLED=true
SSL_CERT_PATH=./certs/astrology.work_bundle.crt
SSL_KEY_PATH=./certs/astrology.work.key

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_H5_APP_ID=
WECHAT_H5_APP_SECRET=
WECHAT_OAUTH_SCOPE=snsapi_base
AMAP_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SEC=604800

DATABASE_URL=postgres://postgres:postgres@postgres:5432/swisseph_api
# Or use the discrete variables below instead of DATABASE_URL
PGHOST=postgres
PGPORT=5432
PGDATABASE=swisseph_api
PGUSER=postgres
PGPASSWORD=postgres
PGSSL=false
